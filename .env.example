# =============================================================================
# DevGarden — environment template
# Copy to `.env` (gitignored) and fill in real values.
# =============================================================================

# ---- PostgreSQL (used by docker-compose) ----
POSTGRES_USER=devgarden
POSTGRES_PASSWORD=change-me
POSTGRES_DB=devgarden
POSTGRES_PORT=5432

# ---- API ----
API_PORT=3001
DATABASE_URL=postgres://devgarden:change-me@localhost:5432/devgarden
# 32+ chars; used by Auth.js / JWT signing
AUTH_SECRET=please-generate-with-openssl-rand-base64-32
# 32 bytes (base64). Used for envelope-encrypting LLM provider credentials.
ENCRYPTION_KEY=please-generate-with-openssl-rand-base64-32
# 32+ chars. Shared between web and api for server-to-server `/internal/*` calls.
INTERNAL_API_SECRET=please-generate-with-openssl-rand-base64-32

# ---- GitHub OAuth App (login) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---- GitHub App (repo access, webhooks) ----
GITHUB_APP_ID=
# PEM contents on one line, escape newlines as \n (or mount via secret in compose override).
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---- Authorization allow-list ----
# Comma-separated GitHub logins allowed to sign in.
OWNER_GITHUB_LOGINS=haesookimDev

# ---- Web ----
WEB_PORT=3000
# Public URL of the WEB app — i.e. what users type in the browser.
# NextAuth uses this to build the OAuth callback redirect_uri sent to GitHub.
# The OAuth App on github.com must register `${AUTH_URL}/api/auth/callback/github`
# as its Authorization callback URL.
# In prod compose this defaults to NEXT_PUBLIC_API_URL if unset — if web and api
# are on different origins, set it explicitly.
AUTH_URL=http://localhost:3000
# Browser-facing API base. Must be reachable from the user's browser.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side API base (only used by the web server itself for internal calls).
# In docker-compose this resolves to the api service hostname; locally use http://localhost:3001.
API_INTERNAL_URL=http://localhost:3001
