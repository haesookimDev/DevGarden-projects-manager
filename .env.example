# =============================================================================
# DevGarden — environment template
# Copy to `.env` (gitignored) and fill in real values.
# =============================================================================

# ---- PostgreSQL (used by docker-compose) ----
POSTGRES_USER=devgarden
POSTGRES_PASSWORD=change-me
POSTGRES_DB=devgarden
POSTGRES_PORT=5432

# ---- API ----
API_PORT=3001
DATABASE_URL=postgres://devgarden:change-me@localhost:5432/devgarden
# 32+ chars; used by Auth.js / JWT signing
AUTH_SECRET=please-generate-with-openssl-rand-base64-32
# 32 bytes (base64). Used for envelope-encrypting LLM provider credentials.
ENCRYPTION_KEY=please-generate-with-openssl-rand-base64-32

# ---- GitHub OAuth App (login) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---- GitHub App (repo access, webhooks) ----
GITHUB_APP_ID=
# PEM contents on one line, escape newlines as \n (or mount via secret in compose override).
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---- Authorization allow-list ----
# Comma-separated GitHub logins allowed to sign in.
OWNER_GITHUB_LOGINS=haesookimDev

# ---- Web ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
