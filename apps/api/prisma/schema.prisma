// DevGarden Prisma schema.
// Source of truth for the database. Docs in docs/db-schema.md describe intent;
// this file is authoritative for column shapes and relations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Users
// =============================================================================

enum UserRole {
  OWNER
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  githubId  Int      @unique
  login     String
  email     String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects              Project[]
  clients               Client[]
  harnesses             Harness[]
  llmProviders          LlmProvider[]
  pairings              ClientPairing[]
  triggeredRuns         HarnessRun[]              @relation("RunTriggeredBy")
  githubAppRegistration GithubAppRegistration?
  budget                OwnerBudget?
  notificationSettings  UserNotificationSettings?
  notifications         Notification[]
}

// Per-user notification preferences (v0.2 N5). Channels (web toast / Slack /
// email) plus per-run-status triggers, with optional per-project overrides.
// slackWebhookUrl is envelope-encrypted (set in the Slack channel PR).
model UserNotificationSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webToast        Boolean  @default(true)
  slackWebhookUrl Bytes?
  emailEnabled    Boolean  @default(false)
  emailAddress    String?
  // { success, failed, cancelled } — which terminal statuses notify.
  triggers        Json     @default("{\"success\": false, \"failed\": true, \"cancelled\": false}")
  // { [projectId]: { success?, failed?, cancelled? } } overrides.
  perProject      Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// A delivered web-toast notification (v0.2 N5). The WebToast channel persists
// one row; the web client reads / streams these and shows a toast. Slack and
// email channels (later PRs) send out-of-band and do not write here.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  body      String?
  runId     String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Per-owner monthly spend cap (v0.2 N6). When monthlyUsdLimit is set, the
// BudgetMonitorService checks spend after each terminal run and flags
// warn (warnAt %) / exceeded (100%) crossings. resetDay is the day-of-month
// the rolling window restarts.
model OwnerBudget {
  ownerId         String   @id
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  monthlyUsdLimit Decimal? @db.Decimal(10, 2)
  warnAt          Int      @default(80)
  resetDay        Int      @default(1)
  updatedAt       DateTime @updatedAt
}

// =============================================================================
// Clients (desktop pairing)
// =============================================================================

enum ClientStatus {
  ONLINE
  OFFLINE
}

model Client {
  id           String       @id @default(cuid())
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  hostname     String?
  os           String?
  version      String?
  jwtTokenHash String
  lastSeenAt   DateTime?
  status       ClientStatus @default(OFFLINE)
  createdAt    DateTime     @default(now())

  defaultForProjects Project[]    @relation("ProjectDefaultClient")
  runs               HarnessRun[]
  presets            RunPreset[]

  @@index([ownerId])
}

model ClientPairing {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clientName String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([ownerId])
  @@index([expiresAt])
}

// =============================================================================
// Projects
// =============================================================================

enum WorktreePolicy {
  KEEP
  AUTO_REMOVE_SUCCESS
  AUTO_REMOVE_ALWAYS
}

// Tracks the state of the local repo clone that lives on a paired client.
// NOT_CLONED means we have a Project row but the client has not yet replicated
// the repo to disk; READY means a working tree exists at `localRoot`.
enum CloneStatus {
  NOT_CLONED
  CLONING
  READY
  FAILED
}

model Project {
  id                    String              @id @default(cuid())
  ownerId               String
  owner                 User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  githubInstallationId  Int
  // FK to the matching GithubInstallation row when one has been synced. The
  // numeric githubInstallationId stays as the source of truth for legacy
  // env-based deployments; the DB id is the new path that picker UIs use.
  installationDbId      String?
  installation          GithubInstallation? @relation(fields: [installationDbId], references: [id], onDelete: SetNull)
  githubRepoId          Int
  repoFullName          String
  defaultClientId       String?
  defaultClient         Client?             @relation("ProjectDefaultClient", fields: [defaultClientId], references: [id])
  defaultHarnessId      String?
  defaultHarness        Harness?            @relation("ProjectDefaultHarness", fields: [defaultHarnessId], references: [id])
  // v0.2 N4: when null, project follows the latest version of defaultHarness
  // (resolved at dispatch time). When set, runs pin to that specific version.
  defaultHarnessVersion Int?
  localRoot             String
  worktreePolicy        WorktreePolicy      @default(AUTO_REMOVE_SUCCESS)
  cloneStatus           CloneStatus         @default(NOT_CLONED)
  cloneError            String?
  cloneCompletedAt      DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  todos        HarnessRun[]
  items        TodoItem[]
  githubEvents GithubEvent[]
  presets      RunPreset[]

  @@unique([ownerId, githubRepoId])
  @@index([repoFullName])
}

// A saved "run this harness on this client with these inputs" combo.
// Per-project; the one with isDefault=true is the project's auto-trigger
// (Quick action button on the detail page).
model RunPreset {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  harnessId String
  harness   Harness  @relation(fields: [harnessId], references: [id], onDelete: Restrict)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  inputs    Json     @default("{}")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

// =============================================================================
// Harness definition + runs
// =============================================================================

model Harness {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  version    Int      @default(1)
  definition Json
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  runs               HarnessRun[]
  defaultForProjects Project[]    @relation("ProjectDefaultHarness")
  presets            RunPreset[]

  // v0.2 N4: every save creates a new version row, so the unique key has to
  // include version. Run history still resolves by id; lists default to the
  // latest per (ownerId, name).
  @@unique([ownerId, name, version])
  @@index([ownerId, name])
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model HarnessRun {
  id                String    @id @default(cuid())
  harnessId         String
  harness           Harness   @relation(fields: [harnessId], references: [id], onDelete: Restrict)
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  triggeredByUserId String
  triggeredBy       User      @relation("RunTriggeredBy", fields: [triggeredByUserId], references: [id])
  status            RunStatus @default(QUEUED)
  branchName        String?
  workingDir        String?
  // v0.2 N5: inputs are persisted at dispatch so a retry can re-run with the
  // exact same payload. Pre-N5 runs default to {}.
  inputs            Json      @default("{}")
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  costUsd           Decimal?  @db.Decimal(10, 6)
  tokenUsage        Json?

  // v0.2 N5 run controls. A retry is a fresh row linked back to its origin so
  // history is preserved. Cancel tracks the request (cancelRequestedAt, set
  // when the user clicks) separately from confirmation (cancelledAt, set when
  // the run actually transitions to CANCELLED) so the UI can show
  // "cancel requested" while the sidecar tears the process down.
  retryOfRunId      String?
  retryOfRun        HarnessRun?  @relation("RunRetry", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries           HarnessRun[] @relation("RunRetry")
  cancelRequestedAt DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  steps     RunStep[]
  logs      RunLog[]
  artifacts RunArtifact[]

  @@index([projectId, startedAt(sort: Desc)])
  @@index([harnessId])
  @@index([harnessId, startedAt(sort: Desc)]) // N6 runs search: harness filter + recency
  @@index([clientId])
  @@index([startedAt(sort: Desc)]) // N6 runs search: owner-wide recency scan
  @@index([retryOfRunId]) // N5: list a run's retries
}

enum StepKind {
  TOOL
  LLM
  SUBAGENT
  CONDITION
  LOOP
}

enum StepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model RunStep {
  id         String     @id @default(cuid())
  runId      String
  run        HarnessRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepIndex  Int
  stepId     String
  kind       StepKind
  input      Json?
  output     Json?
  status     StepStatus @default(PENDING)
  durationMs Int?
  error      String?
  createdAt  DateTime   @default(now())

  @@unique([runId, stepIndex])
  @@index([runId])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model RunLog {
  id      String     @id @default(cuid())
  runId   String
  run     HarnessRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ts      DateTime   @default(now())
  level   LogLevel
  source  String
  message String

  @@index([runId, ts])
}

enum ArtifactKind {
  DIFF
  LOG
  JSON
  BINARY
}

model RunArtifact {
  id        String       @id @default(cuid())
  runId     String
  run       HarnessRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepId    String?
  kind      ArtifactKind
  mimeType  String
  bytes     Bytes?
  filePath  String?
  createdAt DateTime     @default(now())

  @@index([runId])
}

// =============================================================================
// LLM Providers
// =============================================================================

enum LlmProviderKind {
  CODEX_CLI
  OPENAI_COMPATIBLE
}

model LlmProvider {
  id                  String          @id @default(cuid())
  ownerId             String
  owner               User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind                LlmProviderKind
  name                String
  baseUrl             String?
  defaultModel        String
  credentialEncrypted Bytes?
  enabled             Boolean         @default(true)
  createdAt           DateTime        @default(now())

  @@unique([ownerId, name])
}

// =============================================================================
// Todos (internal + mirror of GitHub issues)
// =============================================================================

enum TodoStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TodoSource {
  INTERNAL
  GITHUB_ISSUE
}

model TodoItem {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  body       String?
  status     TodoStatus @default(OPEN)
  sourceType TodoSource @default(INTERNAL)
  sourceRef  Int?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Postgres treats NULL as distinct on uniques, so internal todos (sourceRef=null)
  // can coexist freely. GitHub issues with the same number → one row, upserted.
  @@unique([projectId, sourceType, sourceRef])
  @@index([projectId, status])
}

// =============================================================================
// GitHub webhook event audit
// =============================================================================

model GithubEvent {
  id           String   @id @default(cuid())
  deliveryId   String   @unique
  eventType    String
  action       String?
  repoFullName String?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  payload      Json
  receivedAt   DateTime @default(now())

  @@index([projectId, receivedAt])
  @@index([eventType, receivedAt])
}

// =============================================================================
// GitHub App registration + installations (v0.2 N1 onboarding overhaul)
//
// Pre-N1, GitHub App credentials lived purely in env vars (GITHUB_APP_ID +
// GITHUB_APP_PRIVATE_KEY + GITHUB_WEBHOOK_SECRET) and the installation ID was
// pasted manually by the user on the /dashboard/projects/new form. These two
// models replace that flow:
//   - GithubAppRegistration captures the App itself, sourced via either
//     manifest flow (GitHub-generated credentials returned through callback)
//     or BYO (user pastes appId + PEM directly). Secrets are
//     envelope-encrypted with ENCRYPTION_KEY before persistence.
//   - GithubInstallation mirrors the per-account install of that App. Repo
//     pickers list rows from here instead of asking for a numeric ID.
//
// The legacy env-driven path is intentionally kept alive (GithubAppService
// reads env first, DB second) for at least one minor so existing
// self-hosters can migrate without downtime; the deprecation warning lands
// in a later N1 PR.
// =============================================================================

enum GithubAppSource {
  MANIFEST
  BYO
}

model GithubAppRegistration {
  id            String          @id @default(cuid())
  ownerId       String          @unique
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  source        GithubAppSource
  appId         Int
  appSlug       String?
  webhookSecret Bytes // envelope-encrypted (ENCRYPTION_KEY); nullable inputs handled in service
  privateKeyPem Bytes // envelope-encrypted
  clientId      String?
  clientSecret  Bytes? // envelope-encrypted, populated only on MANIFEST flow
  htmlUrl       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  installations GithubInstallation[]

  @@index([appId])
}

model GithubInstallation {
  id                  String                @id @default(cuid())
  registrationId      String
  registration        GithubAppRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  installationId      Int                   @unique
  accountLogin        String
  accountType         String // "User" | "Organization"
  accountId           Int
  htmlUrl             String?
  permissions         Json // last seen permissions snapshot from GitHub
  events              String[] // subscribed events at last sync
  repositorySelection String // "all" | "selected"
  syncedAt            DateTime              @default(now())

  projects Project[]

  @@index([registrationId])
}
